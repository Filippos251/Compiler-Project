#define T_MAIN   3 
...

//identifier
#define T_ID     4

//operators
#define T_OROP   5
#define T_ANDOP  6
#define T_EQOP   7
...

//other tokens
#define T_SEMI   8
#define T_ASSIGN 9
#define T_COMMA  10
...

//EOF
#define T_EOF    0    // o lex θέλει πάντα το EOF να έχει τη τιμή 0 



